{
  "elements": [
    {
      "type": "Label",
      "label": "MOVAhome Cloud Modul - Testversion fuer MOVA P50 Pro Ultra"
    },
    {
      "type": "ExpansionPanel",
      "caption": "MOVAhome Zugang",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "Username",
          "caption": "MOVAhome E-Mail"
        },
        {
          "type": "PasswordTextBox",
          "name": "Password",
          "caption": "MOVAhome Passwort"
        },
        {
          "type": "Select",
          "name": "Region",
          "caption": "Region",
          "options": [
            { "caption": "EU", "value": "eu" },
            { "caption": "CN", "value": "cn" },
            { "caption": "US", "value": "us" },
            { "caption": "SG", "value": "sg" }
          ]
        },
        {
          "type": "Select",
          "name": "DeviceID",
          "caption": "Gefundenes Geraet",
          "options": [
            { "caption": "Bitte Geraet suchen und auswaehlen", "value": "" }
          ]
        },
        {
          "type": "ValidationTextBox",
          "name": "Model",
          "caption": "Modellfilter (optional)"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Aktualisierung",
      "items": [
        {
          "type": "NumberSpinner",
          "name": "UpdateInterval",
          "caption": "Aktualisierungsintervall (Sekunden)",
          "minimum": 0
        },
        {
          "type": "CheckBox",
          "name": "Debug",
          "caption": "Debug in IPS_LogMessage"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Erweitert",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "BaseUrl",
          "caption": "Basis-URL ueberschreiben (leer = automatisch)"
        },
        {
          "type": "ValidationTextBox",
          "name": "AuthBasic",
          "caption": "Authorization Basic Token (optional)"
        },
        {
          "type": "ValidationTextBox",
          "name": "TenantId",
          "caption": "Tenant-ID"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Login + Geraete suchen",
      "onClick": "MOVA_LoginAndDiscover($id);"
    },
    {
      "type": "Button",
      "caption": "Status aktualisieren",
      "onClick": "MOVA_Update($id);"
    },
    {
      "type": "RowLayout",
      "items": [
        {
          "type": "Button",
          "caption": "Start",
          "onClick": "MOVA_Start($id);"
        },
        {
          "type": "Button",
          "caption": "Pause",
          "onClick": "MOVA_Pause($id);"
        },
        {
          "type": "Button",
          "caption": "Stop",
          "onClick": "MOVA_Stop($id);"
        },
        {
          "type": "Button",
          "caption": "Zur Station",
          "onClick": "MOVA_Dock($id);"
        }
      ]
    },
    {
      "type": "RowLayout",
      "items": [
        {
          "type": "Button",
          "caption": "Roboter suchen",
          "onClick": "MOVA_Locate($id);"
        },
        {
          "type": "Button",
          "caption": "Warnung loeschen",
          "onClick": "MOVA_ClearWarning($id);"
        },
        {
          "type": "Button",
          "caption": "Auto-Entleerung",
          "onClick": "MOVA_StartAutoEmpty($id);"
        }
      ]
    }
  ],
  "status": [
    {
      "code": 104,
      "icon": "inactive",
      "caption": "Keine Zugangsdaten konfiguriert"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "Login/Cloud Fehler - Debug pruefen"
    }
  ]
}
