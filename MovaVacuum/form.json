{
  "elements": [
    {
      "type": "Label",
      "label": "MOVA Vacuum (MOVAhome / P50 Pro Ultra)"
    },

    {
      "type": "ExpansionPanel",
      "caption": "Zugangsdaten",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "Username",
          "caption": "E-Mail"
        },
        {
          "type": "PasswordTextBox",
          "name": "Password",
          "caption": "Passwort"
        },
        {
          "type": "Select",
          "name": "Region",
          "caption": "Region",
          "options": [
            { "caption": "EU", "value": "eu" },
            { "caption": "CN", "value": "cn" },
            { "caption": "US", "value": "us" },
            { "caption": "SG", "value": "sg" }
          ]
        },
        {
          "type": "ValidationTextBox",
          "name": "DeviceID",
          "caption": "Device-ID (aus Debug)"
        }
      ]
    },

    {
      "type": "ExpansionPanel",
      "caption": "Update",
      "items": [
        {
          "type": "NumberSpinner",
          "name": "UpdateInterval",
          "caption": "Intervall (Sekunden)",
          "minimum": 10
        },
        {
          "type": "CheckBox",
          "name": "Debug",
          "caption": "Debug aktivieren"
        }
      ]
    },

    {
      "type": "ExpansionPanel",
      "caption": "Tests",
      "items": [
        {
          "type": "Button",
          "caption": "Cloud Status Test",
          "onClick": "MOVA_TestCloudStatus($id);"
        },
        {
          "type": "Button",
          "caption": "Status aktualisieren",
          "onClick": "MOVA_Update($id);"
        }
      ]
    }
  ],

  "actions": [
    {
      "type": "Button",
      "caption": "Login + Update",
      "onClick": "MOVA_Update($id);"
    }
  ],

  "status": [
    {
      "code": 101,
      "icon": "inactive",
      "caption": "Instanz wird erstellt"
    },
    {
      "code": 102,
      "icon": "active",
      "caption": "Aktiv"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "Fehler (siehe Debug)"
    }
  ]
}
