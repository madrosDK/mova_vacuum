{
  "elements": [
    {
      "type": "Label",
      "label": "MOVA Vacuum (MOVAhome / P50 Pro Ultra)"
    },
    {
      "type": "ExpansionPanel",
      "caption": "Zugangsdaten",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "Username",
          "caption": "E-Mail"
        },
        {
          "type": "PasswordTextBox",
          "name": "Password",
          "caption": "Passwort"
        },
        {
          "type": "Select",
          "name": "Region",
          "caption": "Region",
          "options": [
            {
              "caption": "EU",
              "value": "eu"
            },
            {
              "caption": "CN",
              "value": "cn"
            },
            {
              "caption": "US",
              "value": "us"
            },
            {
              "caption": "SG",
              "value": "sg"
            }
          ]
        },
        {
          "type": "ValidationTextBox",
          "name": "DeviceID",
          "caption": "Device-ID"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Steuerung",
      "items": [
        {
          "type": "Button",
          "caption": "Start",
          "onClick": "MOVA_SendSimpleCommand($id, 'start');"
        },
        {
          "type": "Button",
          "caption": "Pause",
          "onClick": "MOVA_SendSimpleCommand($id, 'pause');"
        },
        {
          "type": "Button",
          "caption": "Dock",
          "onClick": "MOVA_SendSimpleCommand($id, 'charge');"
        },
        {
          "type": "Button",
          "caption": "Stop",
          "onClick": "MOVA_SendSimpleCommand($id, 'stop');"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Test / Debug",
      "items": [
        {
          "type": "Button",
          "caption": "Status aktualisieren",
          "onClick": "MOVA_Update($id);"
        },
        {
          "type": "Button",
          "caption": "Default Properties",
          "onClick": "MOVA_TestDefaultProperties($id);"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Xiaomi / MiIO Cloud Test",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "XiaomiUsername",
          "caption": "Xiaomi/Mi Home E-Mail"
        },
        {
          "type": "PasswordTextBox",
          "name": "XiaomiPassword",
          "caption": "Xiaomi/Mi Home Passwort"
        },
        {
          "type": "Select",
          "name": "XiaomiCountry",
          "caption": "Xiaomi Region",
          "options": [
            {
              "caption": "Deutschland / EU (de)",
              "value": "de"
            },
            {
              "caption": "China (cn)",
              "value": "cn"
            }
          ]
        },
        {
          "type": "ValidationTextBox",
          "name": "XiaomiDeviceID",
          "caption": "Xiaomi DID"
        },
        {
          "type": "Button",
          "caption": "Xiaomi Login testen",
          "onClick": "MOVA_XiaomiLoginTest($id);"
        },
        {
          "type": "Button",
          "caption": "Xiaomi get_properties testen",
          "onClick": "MOVA_XiaomiGetPropertiesTest($id);"
        },
        {
          "type": "Button",
          "caption": "Xiaomi Start testen",
          "onClick": "MOVA_XiaomiStartTest($id);"
        },
        {
          "type": "Button",
          "caption": "Xiaomi Pause testen",
          "onClick": "MOVA_XiaomiPauseTest($id);"
        },
        {
          "type": "Button",
          "caption": "Xiaomi Dock testen",
          "onClick": "MOVA_XiaomiDockTest($id);"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "FastCommand Explorer",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "TestMethod",
          "caption": "Methode"
        },
        {
          "type": "ValidationTextBox",
          "name": "TestParams",
          "caption": "Params JSON"
        },
        {
          "type": "Button",
          "caption": "FastCommand testen",
          "onClick": "MOVA_TestFastCommand($id);"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Update",
      "onClick": "MOVA_Update($id);"
    }
  ],
  "status": [
    {
      "code": 101,
      "icon": "inactive",
      "caption": "Instanz wird erstellt"
    },
    {
      "code": 102,
      "icon": "active",
      "caption": "Aktiv"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "Fehler (Debug prüfen)"
    }
  ]
}