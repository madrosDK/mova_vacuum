{
  "elements": [
    {
      "type": "Label",
      "label": "MOVA Vacuum ReadOnly (MOVAhome / P50 Pro Ultra)"
    },
    {
      "type": "ExpansionPanel",
      "caption": "Aktualisierung",
      "items": [
        {
          "type": "NumberSpinner",
          "name": "UpdateInterval",
          "caption": "Aktualisierungsintervall (Sekunden)",
          "minimum": 0
        },
        {
          "type": "CheckBox",
          "name": "UseMD5Password",
          "caption": "MOVA Passwort mit Salt/MD5 verwenden"
        },
        {
          "type": "CheckBox",
          "name": "Debug",
          "caption": "Debug aktivieren"
        },
        {
          "type": "Button",
          "caption": "Login + Geräte suchen",
          "onClick": "MOVA_LoginAndDiscover($id);"
        },
        {
          "type": "Button",
          "caption": "Status aktualisieren",
          "onClick": "MOVA_Refresh($id);"
        },
        {
          "type": "Button",
          "caption": "Default Properties testen",
          "onClick": "MOVA_TestDefaultProperties($id);"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Expertenwerte",
      "expanded": false,
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "BaseUrl",
          "caption": "Base URL leer = automatisch"
        },
        {
          "type": "ValidationTextBox",
          "name": "AuthBasic",
          "caption": "Auth Basic leer = automatisch"
        },
        {
          "type": "ValidationTextBox",
          "name": "TenantId",
          "caption": "Tenant-ID"
        },
        {
          "type": "ValidationTextBox",
          "name": "Model",
          "caption": "Modellfilter optional"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Status aktualisieren",
      "onClick": "MOVA_Refresh($id);"
    }
  ],
  "status": [
    {
      "code": 101,
      "icon": "inactive",
      "caption": "Instanz wird erstellt"
    },
    {
      "code": 102,
      "icon": "active",
      "caption": "Aktiv"
    },
    {
      "code": 104,
      "icon": "inactive",
      "caption": "Zugangsdaten fehlen"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "Fehler (Debug prüfen)"
    }
  ]
}