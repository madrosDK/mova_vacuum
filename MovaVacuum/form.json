{
  "elements": [
    {"type": "Label", "label": "MOVAhome Cloud Modul - Startversion für MOVA P50 Pro Ultra (mova.vacuum.r2587a)"},
    {"type": "ValidationTextBox", "name": "Username", "caption": "MOVAhome E-Mail"},
    {"type": "PasswordTextBox", "name": "Password", "caption": "MOVAhome Passwort"},
    {
      "type": "Select",
      "name": "Region",
      "caption": "Region",
      "options": [
        {"caption": "EU", "value": "eu"},
        {"caption": "CN", "value": "cn"},
        {"caption": "US", "value": "us"},
        {"caption": "SG", "value": "sg"}
      ]
    },
    {"type": "ValidationTextBox", "name": "DeviceID", "caption": "Device-ID / did (leer = Geräteliste verwenden)"},
    {"type": "NumberSpinner", "name": "UpdateInterval", "caption": "Aktualisierungsintervall (Sekunden)", "minimum": 0},
    {"type": "CheckBox", "name": "UseMD5Password", "caption": "Passwort als MD5 senden (Testoption)"},
    {"type": "CheckBox", "name": "Debug", "caption": "Debug in IPS_LogMessage"},
    {"type": "ExpansionPanel", "caption": "Erweitert", "items": [
      {"type": "ValidationTextBox", "name": "BaseUrl", "caption": "Basis-URL überschreiben (leer = automatisch)"},
      {"type": "ValidationTextBox", "name": "AuthBasic", "caption": "Authorization Basic Token"},
      {"type": "ValidationTextBox", "name": "TenantId", "caption": "Tenant-ID"},
      {"type": "ValidationTextBox", "name": "Model", "caption": "Modellfilter"}
    ]}
  ],
  "actions": [
    {"type": "Button", "caption": "Login + Geräte suchen", "onClick": "MOVA_LoginAndDiscover($id);"},
    {"type": "Button", "caption": "Status aktualisieren", "onClick": "MOVA_Update($id);"},
    {"type": "Button", "caption": "Start", "onClick": "MOVA_Start($id);"},
    {"type": "Button", "caption": "Pause", "onClick": "MOVA_Pause($id);"},
    {"type": "Button", "caption": "Zur Station", "onClick": "MOVA_Dock($id);"}
  ],
  "status": [
    {"code": 101, "icon": "inactive", "caption": "Keine Zugangsdaten konfiguriert"},
    {"code": 102, "icon": "error", "caption": "Login/Cloud Fehler - Debug prüfen"}
  ]
}
